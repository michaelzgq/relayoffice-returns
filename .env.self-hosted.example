APP_NAME="RelayOffice Returns"
APP_ENV=production
APP_DEBUG=false
DEBUGBAR_ENABLED=false
APP_MODE=live
APP_URL=http://localhost:8080
FORCE_HTTPS=false
APP_KEY_BASE64=replace-with-openssl-rand-base64-32

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=relayoffice
DB_USERNAME=relayoffice
DB_PASSWORD=change-me-db-password

MYSQL_DATABASE=relayoffice
MYSQL_USER=relayoffice
MYSQL_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

APP_HOST_PORT=8080
SELF_HOSTED_BOOTSTRAP_MODE=blank
